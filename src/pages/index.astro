---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';
import { frontmatter } from '../content.md';

const c = frontmatter;
---

<Layout>

<!-- ═══════════════════════════════════════
     NAVIGATION
═══════════════════════════════════════ -->
<header id="top">
  <nav>
    <div class="nav-inner container">
      <a href="#top" class="nav-logo" aria-label="KMP Tapping home">
        <img src="/logo.png" alt="KMP Tapping" width="160" height="48" />
      </a>
      <ul class="nav-links" role="list">
        <li><a href="#services">Services</a></li>
        <li><a href="#products">Products</a></li>
        <li><a href="#projects">Projects</a></li>
        <li><a href="#contact" class="nav-cta">Contact Us</a></li>
      </ul>
      <button class="nav-toggle" aria-label="Toggle menu" aria-expanded="false">
        <span></span><span></span><span></span>
      </button>
    </div>
  </nav>
</header>


<!-- ═══════════════════════════════════════
     HERO
═══════════════════════════════════════ -->
<section class="hero" aria-label="Hero">
  <div class="hero-bg-grid" aria-hidden="true"></div>
  <div class="hero-pipeline" aria-hidden="true"></div>
  <div class="container hero-inner">
    <div class="hero-content">
      <p class="section-label">{c.tagline}</p>
      <h1 class="hero-title">
        {c.heroTitle.split('&')[0]}&<br />
        <span>{c.heroTitle.split('&')[1].trim().split(' ').slice(0,2).join(' ')}</span><br />
        {c.heroTitle.split('&')[1].trim().split(' ').slice(2).join(' ')}
      </h1>
      <p class="hero-sub">{c.heroSub}</p>
      <div class="hero-actions">
        <a href="#services" class="btn-primary">Our Services</a>
        <a href="#contact" class="btn-ghost">Get a Quote</a>
      </div>
    </div>
    <div class="hero-visual" aria-hidden="true">
      <div class="img-placeholder hero-img">
        <svg width="48" height="48" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><rect x="2" y="7" width="20" height="10" rx="2"/><path d="M2 12h20M7 7v10M17 7v10"/></svg>
        Add hero image here
      </div>
    </div>
  </div>
  <div class="hero-stats">
    <div class="container">
      <div class="stats-row">
        <div class="stat">
          <span class="stat-num">Zero</span>
          <span class="stat-label">{c.stat1Label}</span>
        </div>
        <div class="stat-divider" aria-hidden="true"></div>
        <div class="stat">
          <span class="stat-num">Live</span>
          <span class="stat-label">{c.stat2Label}</span>
        </div>
        <div class="stat-divider" aria-hidden="true"></div>
        <div class="stat">
          <span class="stat-num">Africa</span>
          <span class="stat-label">{c.stat3Label}</span>
        </div>
        <div class="stat-divider" aria-hidden="true"></div>
        <div class="stat">
          <span class="stat-num">End-to-end</span>
          <span class="stat-label">{c.stat4Label}</span>
        </div>
      </div>
    </div>
  </div>
</section>


<!-- ═══════════════════════════════════════
     SERVICES
═══════════════════════════════════════ -->
<section class="section services-section" id="services" aria-labelledby="services-heading">
  <div class="container">
    <p class="section-label">{c.servicesLabel}</p>
    <h2 class="section-title" id="services-heading">Our <span>Services</span></h2>
    <div class="accent-line"></div>
    <p class="section-intro">{c.servicesIntro}</p>

    <div class="services-grid">

      <div class="service-card service-card--featured">
        <div class="service-card-img img-placeholder">
          <svg width="40" height="40" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><circle cx="12" cy="12" r="3"/><path d="M12 2v4M12 18v4M4.22 4.22l2.83 2.83M16.95 16.95l2.83 2.83M2 12h4M18 12h4M4.22 19.78l2.83-2.83M16.95 7.05l2.83-2.83"/></svg>
          Hot tapping image
        </div>
        <div class="service-card-body">
          <span class="service-tag">{c.service1Tag}</span>
          <h3>{c.service1Title}</h3>
          <p>{c.service1Body1}</p>
          <p>{c.service1Body2}</p>
          <ul class="service-list">
            <li>{c.service1li1}</li>
            <li>{c.service1li2}</li>
            <li>{c.service1li3}</li>
            <li>{c.service1li4}</li>
          </ul>
        </div>
      </div>

      <div class="service-card service-card--featured">
        <div class="service-card-img img-placeholder">
          <svg width="40" height="40" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M18 8h1a4 4 0 0 1 0 8h-1"/><path d="M2 8h16v9a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4V8z"/><line x1="6" y1="1" x2="6" y2="4"/><line x1="10" y1="1" x2="10" y2="4"/><line x1="14" y1="1" x2="14" y2="4"/></svg>
          Line stopping image
        </div>
        <div class="service-card-body">
          <span class="service-tag">{c.service2Tag}</span>
          <h3>{c.service2Title}</h3>
          <p>{c.service2Body1}</p>
          <p>{c.service2Body2}</p>
          <ul class="service-list">
            <li>{c.service2li1}</li>
            <li>{c.service2li2}</li>
            <li>{c.service2li3}</li>
            <li>{c.service2li4}</li>
          </ul>
        </div>
      </div>

    </div>
  </div>
</section>


<!-- ═══════════════════════════════════════
     PRODUCTS
═══════════════════════════════════════ -->
<section class="section products-section" id="products" aria-labelledby="products-heading">
  <div class="container">
    <p class="section-label">{c.productsLabel}</p>
    <h2 class="section-title" id="products-heading">Our <span>Products</span></h2>
    <div class="accent-line"></div>
    <p class="section-intro">{c.productsIntro}</p>

    <div class="products-grid">

      <div class="product-card">
        <div class="product-img img-placeholder">
          <svg width="32" height="32" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z"/><line x1="4" y1="22" x2="4" y2="15"/></svg>
          Fittings image
        </div>
        <div class="product-body">
          <h3>{c.product1Title}</h3>
          <p>{c.product1Body}</p>
          <a href="#contact" class="product-link">Enquire about fittings →</a>
        </div>
      </div>

      <div class="product-card">
        <div class="product-img img-placeholder">
          <svg width="32" height="32" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/></svg>
          Valves image
        </div>
        <div class="product-body">
          <h3>{c.product2Title}</h3>
          <p>{c.product2Body}</p>
          <a href="#contact" class="product-link">Enquire about valves →</a>
        </div>
      </div>

      <div class="product-card">
        <div class="product-img img-placeholder">
          <svg width="32" height="32" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>
          Manual machine image
        </div>
        <div class="product-body">
          <h3>{c.product3Title}</h3>
          <p>{c.product3Body}</p>
          <a href="#contact" class="product-link">Enquire about machines →</a>
        </div>
      </div>

      <div class="product-card">
        <div class="product-img img-placeholder">
          <svg width="32" height="32" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
          Hydraulic machine image
        </div>
        <div class="product-body">
          <h3>{c.product4Title}</h3>
          <p>{c.product4Body}</p>
          <a href="#contact" class="product-link">Enquire about machines →</a>
        </div>
      </div>

    </div>
  </div>
</section>


<!-- ═══════════════════════════════════════
     PROJECTS
═══════════════════════════════════════ -->
<section class="section projects-section" id="projects" aria-labelledby="projects-heading">
  <div class="container">
    <p class="section-label">{c.projectsLabel}</p>
    <h2 class="section-title" id="projects-heading">Selected <span>Projects</span></h2>
    <div class="accent-line"></div>
    <p class="section-intro">{c.projectsIntro}</p>

    <div class="projects-grid">

      <article class="project-card">
        <div class="project-img img-placeholder">
          <svg width="28" height="28" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
          Project image
        </div>
        <div class="project-body">
          <span class="project-tag">{c.project1Tag}</span>
          <h3>{c.project1Title}</h3>
          <p>{c.project1Body}</p>
          <div class="project-meta">
            <span>{c.project1meta1}</span>
            <span>·</span>
            <span>{c.project1meta2}</span>
          </div>
        </div>
      </article>

      <article class="project-card">
        <div class="project-img img-placeholder">
          <svg width="28" height="28" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
          Project image
        </div>
        <div class="project-body">
          <span class="project-tag">{c.project2Tag}</span>
          <h3>{c.project2Title}</h3>
          <p>{c.project2Body}</p>
          <div class="project-meta">
            <span>{c.project2meta1}</span>
            <span>·</span>
            <span>{c.project2meta2}</span>
          </div>
        </div>
      </article>

      <article class="project-card">
        <div class="project-img img-placeholder">
          <svg width="28" height="28" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
          Project image
        </div>
        <div class="project-body">
          <span class="project-tag">{c.project3Tag}</span>
          <h3>{c.project3Title}</h3>
          <p>{c.project3Body}</p>
          <div class="project-meta">
            <span>{c.project3meta1}</span>
            <span>·</span>
            <span>{c.project3meta2}</span>
          </div>
        </div>
      </article>

    </div>

    <p class="projects-note">
      Detailed project references and case studies are available on request. <a href="#contact">Contact us →</a>
    </p>
  </div>
</section>


<!-- ═══════════════════════════════════════
     CONTACT
═══════════════════════════════════════ -->
<section class="section contact-section" id="contact" aria-labelledby="contact-heading">
  <div class="container">
    <p class="section-label">{c.contactLabel}</p>
    <h2 class="section-title" id="contact-heading">Let's <span>Talk</span></h2>
    <div class="accent-line"></div>

    <div class="contact-grid">
      <div class="contact-info">
        <p class="contact-intro">{c.contactIntro}</p>

        <div class="contact-items">
          <a href={`tel:${c.phone.replace(/\s/g,'')}`} class="contact-item">
            <div class="contact-icon" aria-hidden="true">
              <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.27h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.91a16 16 0 0 0 6.08 6.08l.97-.97a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            </div>
            <div>
              <span class="contact-label">Phone & WhatsApp</span>
              <span class="contact-value">{c.phone}</span>
            </div>
          </a>

          <a href={`mailto:${c.email}`} class="contact-item">
            <div class="contact-icon" aria-hidden="true">
              <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            </div>
            <div>
              <span class="contact-label">Email</span>
              <span class="contact-value">{c.email}</span>
            </div>
          </a>

          <div class="contact-item contact-item--location">
            <div class="contact-icon" aria-hidden="true">
              <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            </div>
            <div>
              <span class="contact-label">Based in</span>
              <span class="contact-value">{c.location}</span>
            </div>
          </div>
        </div>

        <a href={`https://wa.me/${c.phone.replace(/\D/g,'')}`} class="btn-whatsapp" target="_blank" rel="noopener noreferrer">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/></svg>
          Chat on WhatsApp
        </a>
      </div>

      <div class="contact-visual" aria-hidden="true">
        <div class="img-placeholder contact-img">
          <svg width="40" height="40" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
          Team or operations photo
        </div>
      </div>
    </div>
  </div>
</section>


<!-- ═══════════════════════════════════════
     FOOTER
═══════════════════════════════════════ -->
<footer>
  <div class="container footer-inner">
    <div class="footer-logo">
      <img src="/logo.png" alt="KMP Tapping" width="120" height="36" />
      <p>{c.footerTagline}</p>
    </div>
    <nav class="footer-nav" aria-label="Footer navigation">
      <a href="#services">Services</a>
      <a href="#products">Products</a>
      <a href="#projects">Projects</a>
      <a href="#contact">Contact</a>
    </nav>
    <p class="footer-copy">&copy; 2025 KMP Tapping. All rights reserved.</p>
  </div>
</footer>

</Layout>

<style>
/* ─── NAV ─────────────────────────────── */
header {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: rgba(1, 24, 36, 0.92);
  backdrop-filter: blur(12px);
  border-bottom: 1px solid rgba(255,255,255,0.06);
}

nav { padding: 0; }

.nav-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 68px;
}

.nav-logo img { height: 40px; width: auto; }

.nav-links {
  display: flex;
  list-style: none;
  gap: 2rem;
  align-items: center;
}

.nav-links a {
  font-family: var(--font-body);
  font-size: 14px;
  font-weight: 500;
  color: var(--mid-gray);
  letter-spacing: 0.03em;
  transition: color 0.2s;
}

.nav-links a:hover { color: var(--white); }

.nav-cta {
  background: var(--orange) !important;
  color: var(--white) !important;
  padding: 8px 20px;
  border-radius: 4px;
  font-weight: 600 !important;
  transition: background 0.2s !important;
}

.nav-cta:hover { background: var(--orange-dark) !important; }

.nav-toggle {
  display: none;
  flex-direction: column;
  gap: 5px;
  background: none;
  border: none;
  cursor: pointer;
  padding: 4px;
}

.nav-toggle span {
  display: block;
  width: 24px;
  height: 2px;
  background: var(--white);
  border-radius: 2px;
  transition: all 0.3s;
}

/* ─── HERO ─────────────────────────────── */
.hero {
  position: relative;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding-top: 68px;
  overflow: hidden;
  background: var(--navy-dark);
}

.hero-bg-grid {
  position: absolute;
  inset: 0;
  background-image:
    linear-gradient(rgba(0,184,176,0.04) 1px, transparent 1px),
    linear-gradient(90deg, rgba(0,184,176,0.04) 1px, transparent 1px);
  background-size: 60px 60px;
  pointer-events: none;
}

.hero-pipeline {
  position: absolute;
  bottom: 120px;
  left: 0;
  right: 0;
  height: 6px;
  background: linear-gradient(90deg, transparent, rgba(251,133,0,0.3) 20%, rgba(251,133,0,0.6) 50%, rgba(251,133,0,0.3) 80%, transparent);
  pointer-events: none;
}

.hero-inner {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 4rem;
  align-items: center;
  padding-top: 4rem;
  padding-bottom: 140px;
}

.hero-title {
  font-family: var(--font-display);
  font-size: clamp(52px, 7vw, 88px);
  font-weight: 800;
  line-height: 1.0;
  color: var(--white);
  text-transform: uppercase;
  margin-bottom: 1.5rem;
}

.hero-title span { color: var(--orange); }

.hero-sub {
  font-size: 17px;
  font-weight: 300;
  color: var(--mid-gray);
  line-height: 1.8;
  margin-bottom: 2.5rem;
  max-width: 480px;
}

.hero-actions {
  display: flex;
  gap: 1rem;
  flex-wrap: wrap;
}

.btn-primary {
  display: inline-block;
  background: var(--orange);
  color: var(--white);
  font-family: var(--font-display);
  font-weight: 700;
  font-size: 15px;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  padding: 14px 32px;
  border-radius: 4px;
  transition: background 0.2s, transform 0.15s;
}

.btn-primary:hover {
  background: var(--orange-dark);
  transform: translateY(-1px);
}

.btn-ghost {
  display: inline-block;
  color: var(--white);
  font-family: var(--font-display);
  font-weight: 700;
  font-size: 15px;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  padding: 13px 32px;
  border-radius: 4px;
  border: 1px solid rgba(255,255,255,0.2);
  transition: border-color 0.2s, transform 0.15s;
}

.btn-ghost:hover {
  border-color: rgba(255,255,255,0.5);
  transform: translateY(-1px);
}

.hero-img {
  height: 420px;
  border-radius: 8px;
  border: 1px solid rgba(251,133,0,0.2);
}

/* stats bar */
.hero-stats {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: rgba(3,68,102,0.5);
  border-top: 1px solid rgba(255,255,255,0.07);
  padding: 20px 0;
}

.stats-row {
  display: flex;
  align-items: center;
  gap: 0;
}

.stat {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 2px;
}

.stat-num {
  font-family: var(--font-display);
  font-size: 20px;
  font-weight: 800;
  color: var(--orange);
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

.stat-label {
  font-size: 12px;
  color: var(--mid-gray);
  text-align: center;
}

.stat-divider {
  width: 1px;
  height: 40px;
  background: rgba(255,255,255,0.1);
  flex-shrink: 0;
}

/* ─── SERVICES ─────────────────────────── */
.services-section {
  background: var(--navy);
}

.services-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 2rem;
  margin-top: 3rem;
}

.service-card {
  background: var(--navy-dark);
  border: 1px solid rgba(255,255,255,0.06);
  border-radius: 8px;
  overflow: hidden;
  transition: border-color 0.3s;
}

.service-card:hover { border-color: rgba(251,133,0,0.3); }

